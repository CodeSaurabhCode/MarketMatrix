# ==========================
# Application Settings
# ==========================
APP_DEBUG=false
APP_LOG_LEVEL=INFO

# ==========================
# Angel One SmartAPI
# ==========================
ANGEL_API_KEY=your_api_key_here
ANGEL_CLIENT_CODE=your_client_code
ANGEL_PASSWORD=your_password
ANGEL_TOTP_SECRET=your_totp_secret

# ==========================
# PostgreSQL / TimescaleDB
# ==========================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trading_signals
DB_USER=postgres
DB_PASSWORD=postgres

# ==========================
# Redis
# ==========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ==========================
# Telegram Notifications
# ==========================
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
TELEGRAM_ENABLED=true

# ==========================
# Signal Detection Thresholds
# ==========================
SIGNAL_MIN_CONFIDENCE_SCORE=80.0
SIGNAL_LOOKBACK_PERIODS=50
SIGNAL_EQUAL_LEVEL_TOLERANCE=0.001
SIGNAL_FVG_MIN_GAP_PERCENT=0.1
SIGNAL_VOLUME_SPIKE_THRESHOLD=2.0
SIGNAL_SWEEP_MIN_WICK_RATIO=0.6
SIGNAL_VWAP_PROXIMITY_PERCENT=0.3
